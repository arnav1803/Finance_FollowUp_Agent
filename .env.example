# ── AI Provider (Groq) ────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Email Sending ─────────────────────────────────────────────────────
# Options: dry_run (default), smtp
SEND_MODE=dry_run
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SENDER_EMAIL=noreply@example.com

# ── Scheduling (Optional) ────────────────────────────────────────────
SCHEDULE_ENABLED=false
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0

# ── Mock Mode (Optional) ─────────────────────────────────────────────
# Set to true to force mock mode even with a valid API key
MOCK_MODE=false

# ── Observability (Optional — LangSmith) ─────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=Finance_FollowUp_Agent